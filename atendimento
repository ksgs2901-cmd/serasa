<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Atendimento</title>
  <script src="https://cdn.utmify.com.br/scripts/utms/latest.js" data-utmify-prevent-subids async defer></script>
  <script>
    window.pixelId = "67f846e3e19eff9c461bb215";
    var a = document.createElement("script");
    a.setAttribute("async", "");
    a.setAttribute("defer", "");
    a.setAttribute("src", "https://cdn.utmify.com.br/scripts/pixel/pixel.js");
    document.head.appendChild(a);
  </script>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; background: #fff; font-family: Roboto, sans-serif; }

    #loading {
      position: fixed;
      inset: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      background: #fff;
      z-index: 10;
    }

    .spinner {
      width: 40px;
      height: 40px;
      border: 4px solid #f0f0f0;
      border-top-color: #E80070;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    #loading p { color: #555; font-size: 16px; }

    #error {
      display: none;
      position: fixed;
      inset: 0;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 16px;
      padding: 24px;
      text-align: center;
      background: #fff;
      z-index: 20;
    }

    #error h2 { font-size: 20px; color: #111; }
    #error p { color: #666; font-size: 15px; max-width: 400px; line-height: 1.5; }

    #error button, #error a.btn {
      display: inline-block;
      padding: 12px 24px;
      font-size: 15px;
      font-weight: 600;
      color: #fff;
      background: #E80070;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      text-decoration: none;
    }

    #error button:hover, #error a.btn:hover { background: #c9005f; }

    typebot-standard {
      width: 100%;
      height: 100vh;
      display: block;
    }
  </style>
</head>
<body>
  <div id="loading">
    <div class="spinner"></div>
    <p>Conectando ao atendimento...</p>
  </div>

  <div id="error">
    <h2>Não foi possível carregar o atendimento</h2>
    <p id="error-message">O servidor do chat está temporariamente indisponível. Tente novamente ou acesse diretamente.</p>
    <button type="button" id="retry-btn">Tentar novamente</button>
    <a class="btn" id="direct-link" href="#" target="_blank" rel="noopener">Abrir chat diretamente</a>
  </div>

  <typebot-standard style="width:100%;height:100vh;display:block;"></typebot-standard>

  <script type="module">
    const TYPEBOT_ID = "bfilyz";
    const API_HOST = "https://bot-typebot-viewer.ksrub8.easypanel.host";

    const loadingEl = document.getElementById("loading");
    const errorEl = document.getElementById("error");
    const errorMessageEl = document.getElementById("error-message");
    const retryBtn = document.getElementById("retry-btn");
    const directLink = document.getElementById("direct-link");

    function getPrefilledVariables() {
      const params = new URLSearchParams(window.location.search);
      const vars = {};
      params.forEach(function (value, key) {
        if (value) vars[key] = value;
      });
      return vars;
    }

    function getDirectUrl() {
      return API_HOST + "/" + TYPEBOT_ID + window.location.search;
    }

    function showError(message) {
      loadingEl.style.display = "none";
      errorEl.style.display = "flex";
      if (message) errorMessageEl.textContent = message;
      directLink.href = getDirectUrl();
    }

    function hideLoading() {
      loadingEl.style.display = "none";
      errorEl.style.display = "none";
    }

    async function initTypebot() {
      loadingEl.style.display = "flex";
      errorEl.style.display = "none";
      directLink.href = getDirectUrl();

      try {
        const Typebot = (await import("https://cdn.jsdelivr.net/npm/@typebot.io/js@0/dist/web.js")).default;

        let initialized = false;

        Typebot.initStandard({
          typebot: TYPEBOT_ID,
          apiHost: API_HOST,
          prefilledVariables: getPrefilledVariables(),
          onInit: function () {
            initialized = true;
            hideLoading();
          }
        });

        setTimeout(function () {
          if (!initialized) {
            showError("O atendimento está demorando para responder. Verifique sua conexão ou tente abrir o chat diretamente.");
          }
        }, 15000);
      } catch (err) {
        console.error("Erro ao iniciar Typebot:", err);
        showError("Erro ao carregar o chat. Tente novamente em alguns instantes.");
      }
    }

    retryBtn.addEventListener("click", function () {
      window.location.reload();
    });

    if (!window.location.search.includes("cpf=")) {
      window.location.replace("/cpf" + window.location.search);
    } else {
      initTypebot();
    }
  </script>
</body>
</html>
