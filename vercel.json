{
  "rewrites": [
    { "source": "/", "destination": "/index" },
    { "source": "/cpf", "destination": "/cpf" },
    { "source": "/atendimento", "destination": "/atendimento" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
